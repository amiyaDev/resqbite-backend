  "description": "Backend service for ResQBite — a surplus food marketplace platform enabling sellers to list excess food, buyers to purchase with OTP-based pickup, and automated NGO redistribution.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
